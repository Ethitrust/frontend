# Upstream Ethitrust API (server-side Route Handlers only; never NEXT_PUBLIC_).
# Used when NEXT_API_INTERNAL_URL is unset (typical local dev: call public API directly).
NEXT_API_URL=https://api.ethitrust.me

# Production VPS: set if the public API hostname is behind Cloudflare.
# Server-side fetch() cannot complete CF’s browser challenge → 403 HTML unless you bypass CF.
# Point this at the same origin your reverse proxy uses (loopback, private IP, Docker service).
# Example: NEXT_API_INTERNAL_URL=http://127.0.0.1:8000
